#!/usr/bin/env bash
# ============================================================
# ADO-Core: Project Configuration (Dogfood — Full Observability)
# File: .agent-plugins/config.env  (per-repo, gitignored)
# ============================================================

# ─── Git & Release Flow ───────────────────────────────────────────────────────
# If true, bin/agent push master routes through the PR engine instead of fast-forward merging locally.
export ADO_PR_ENGINE_ENABLED=true

# If 1, automatically deletes the local feature branch and remote tracking branch after successful merge.
export ADO_AUTO_DELETE_MERGED_BRANCHES=1

# If 1, automatically updates the local OS version when upstream changes are detected.
export ADO_AUTO_UPDATE=1

# If 1, enables local Git worktrees for safe parallel branch execution.
# export ADO_USE_WORKTREES=1


# ─── Quality Gates ────────────────────────────────────────────────────────────
# If true, enforces TDD constraints on logic file modifications.
export ADO_TDD_ENFORCEMENT=true

# If true, enables Multimodal Visual Test-Driven Development (VTDD) validation.
# export ADO_VTDD_ENFORCEMENT=true

# If true, enforces Human-in-the-Loop review gates during commit execution.
# export ADO_ENFORCE_COMMIT_REVIEW=false

# Regex pattern to ignore files in the Contract-First compliance check.
export ADO_CONTRACT_EXCLUDE_PATTERN="(_test\.go|\.test\.|\.spec\.|/tests?/|/testing/|^test_)"

# Regex pattern to ignore files in the Boy Scout Rule (legacy docstring) check.
export ADO_LEGACY_EXCLUDE_PATTERN="(_test\.go|\.test\.|\.spec\.|/tests?/|/testing/|^test_)"

# Regex pattern defining the explicit architectural boundaries of the project.
export ADO_DOC_DRIFT_ARCH_PATTERN="^.agent-plugins/|^package\.json$|^go\.mod$|^Cargo\.toml$|^pyproject\.toml$|^.agent/workflows/|^bin/"




# ─── Agent Identity & Tracking ────────────────────────────────────────────────
# Primary task/backlog tracker for this repository.
export ADO_DEFAULT_TASK_TRACKER="github"

# Primary version control provider for this repository.
export ADO_DEFAULT_GIT_PROVIDER="github"

# Active driving AI Agent's identity name.
export ADO_AGENT_NAME="AG"


# ─── Logging ──────────────────────────────────────────────────────────────────
# Minimum log level written to .agent/logs/os.log.
export ADO_LOG_LEVEL="INFO"


# ─── Fleet Health & Dashboard ─────────────────────────────────────────────────
# Set to 1 to enable automatic version drift checking and issue filing.
export ADO_HEALTH_REPORT=0

# Target repository for fleet health reporting.
# export ADO_HEALTH_REPORT_REPO=""

# Auto-publish the ADO live dashboard to a pinned GitHub Issue after each push.
# export ADO_DASHBOARD_PUBLISH=0

# Auto-move GitHub Project board cards based on phase transitions.
# export ADO_KANBAN_SYNC=0

# Number of days to calculate the sprint velocity against.
export ADO_SPRINT_DAYS=14

# Auto-publish Wiki Specification files to the project wiki on change.
# export ADO_PUBLISH_WIKI_SPECS=0

# Directory path containing peer repos (for fleet-level dashboarding).
# export ADO_NEIGHBORS_DIR=""


# ─── Task Tracker (Project-Level Overrides) ───────────────────────────────────
# Base URL for the task tracker API (if using self-hosted Jira/GitLab).
# export ADO_TASK_BASE_URL=""

# Jira-specific project keys and credentials.
# export ADO_JIRA_PROJECT_KEY=""
# export ADO_JIRA_EPIC_KEY=""
# export ADO_JIRA_USER=""


# ─── Internal Storage & Memory ────────────────────────────────────────────────
# Target Git ref for GitBrain semantic notes storage.
export ADO_GIT_NOTES_REF="refs/notes/agent"


# ─── Event Bus & Telemetry ────────────────────────────────────────────────────
# Level of detail task tracker receives from the Phase Lifecycle Bus.
export ADO_TASK_TELEMETRY="standard"


# ─── Local Inference Swarm ────────────────────────────────────────────────────
# Target URL for local Llama.cpp inference backend (used for GitBrain/agent local RAG).
# export DO_LOCAL_LLAMA_URL="http://127.0.0.1:8081"


# ─── Host / Conduit Integration ───────────────────────────────────────────────
# Explicit path to the Conduit CLI on the host machine.
# export ADO_CONDUIT_PATH=""

# Dynamically resolve host IP address for browser bridge.
# export CONDUIT_HOST=$(ip route | awk '/^default/ {print $3}')

# ─── Custom Developer Overrides ───────────────────────────────────────────────
export ADO_SWARM_ENGINE="aider"
